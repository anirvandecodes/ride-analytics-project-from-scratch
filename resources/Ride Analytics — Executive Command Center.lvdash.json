{
  "datasets": [
    {
      "name": "2f678632",
      "displayName": "Live KPIs",
      "queryLines": [
        "SELECT \n",
        "total_revenue_inr,\n",
        "cancellation_rate_pct,\n",
        "active_drivers,\n",
        "avg_fare_inr,\n",
        "CAST(ROUND(total_rides * (100 - cancellation_rate_pct) / 100, 0) AS BIGINT) AS completed_rides \n",
        "from workspace.realtime.gold_live_kpis"
      ]
    },
    {
      "name": "6350157f",
      "displayName": "Revenue per Minute",
      "queryLines": [
        "SELECT minute_bucket, \n",
        "revenue_inr, \n",
        "completed_rides \n",
        "FROM workspace.realtime.gold_revenue_per_minute \n",
        "ORDER BY minute_bucket"
      ]
    },
    {
      "name": "c3f341b5",
      "displayName": "Ride Status Mix",
      "queryLines": [
        "SELECT status, CAST(ride_count AS BIGINT) AS ride_count FROM workspace.realtime.gold_ride_status_breakdown ORDER BY ride_count DESC"
      ]
    },
    {
      "name": "cfe5ae70",
      "displayName": "City Performance",
      "queryLines": [
        "SELECT city, ROUND(revenue_inr, 0) AS revenue_inr FROM workspace.realtime.gold_rides_by_city ORDER BY revenue_inr DESC"
      ]
    },
    {
      "name": "9f783435",
      "displayName": "Top Revenue Zones",
      "queryLines": [
        "SELECT zone_id, city, ROUND(total_revenue_inr, 0) AS total_revenue_inr, CAST(completed_rides AS BIGINT) AS completed_rides, ROUND(avg_fare_inr, 0) AS avg_fare_inr FROM workspace.realtime.gold_top_zones ORDER BY total_revenue_inr DESC LIMIT 10"
      ]
    },
    {
      "name": "509fed48",
      "displayName": "Cancellation Reasons",
      "queryLines": [
        "SELECT city, COALESCE(NULLIF(cancellation_reason,''), status) AS reason, CAST(SUM(cancellation_count) AS BIGINT) AS cancellation_count FROM workspace.realtime.gold_cancellation_analysis GROUP BY city, COALESCE(NULLIF(cancellation_reason,''), status) ORDER BY cancellation_count DESC"
      ]
    },
    {
      "name": "c7d78668",
      "displayName": "Pickup Demand",
      "queryLines": [
        "SELECT city, pickup_area, zone_id, CAST(SUM(total_rides) AS BIGINT) AS total_rides, CAST(SUM(cancelled_rides) AS BIGINT) AS cancelled_rides, ROUND(SUM(cancelled_rides) * 100.0 / NULLIF(SUM(total_rides), 0), 1) AS cancel_rate_pct FROM workspace.realtime.gold_pickup_demand GROUP BY city, pickup_area, zone_id ORDER BY total_rides DESC"
      ]
    }
  ],
